---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const projects = [
	{
		title: 'Superhero Search App',
		description: 'Full-stack tech test. Search for superheroes, view their power stats, edit them, and save to a personal list. Built a GraphQL API from scratch backed by AWS DynamoDB — having never used GraphQL before.',
		tags: ['React', 'GraphQL', 'Express.js', 'AWS DynamoDB', 'JavaScript'],
		live: null,
		github: null,
		githubLinks: [
			{ label: 'Frontend', url: 'https://github.com/YujinOk/client-superhero' },
			{ label: 'Backend', url: 'https://github.com/YujinOk/graphql-superhero' },
		],
	},
	{
		title: 'Calculator',
		description: 'A fully functional calculator built from scratch.',
		tags: ['HTML', 'CSS', 'SCSS', 'JavaScript'],
		live: 'https://yujinok.github.io/calculator/',
		github: 'https://github.com/YujinOk/calculator',
		githubLinks: null,
		image: '/img/calculator.png',
	},
	{
		title: 'Google Book UI',
		description: 'A UI clone of Google Books with search functionality.',
		tags: ['HTML', 'CSS', 'SCSS', 'JavaScript'],
		live: null,
		github: 'https://github.com/YujinOk/googlebookui',
		githubLinks: null,
	},
	{
		title: 'K-Ecommerce Store',
		description: 'A Korean-themed ecommerce storefront built with React.',
		tags: ['React', 'CSS', 'SCSS', 'JavaScript'],
		live: 'https://yujinok.github.io/ecommerce/',
		github: 'https://github.com/YujinOk/ecommerce',
		githubLinks: null,
	},
];
---

<html lang="en">
	<head>
		<BaseHead title="Projects | Yujin Ok" description="Things I've built." />
		<style>
			main {
				max-width: 900px;
				margin: 0 auto;
				padding: 2em 1em;
			}
			h1 {
				margin-bottom: 0.25em;
			}
			hr {
				margin: 1em 0 2em;
				border: none;
				border-top: 1px solid rgb(var(--gray-light));
			}
			.grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.5em;
			}
			.card {
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				overflow: hidden;
				display: flex;
				flex-direction: column;
			}
			.card-placeholder {
				width: 100%;
				height: 180px;
				background: rgb(var(--gray-light));
				display: flex;
				align-items: center;
				justify-content: center;
				color: rgb(var(--gray));
				font-size: 0.85rem;
			}
			.card-body {
				padding: 1.2em;
				flex: 1;
				display: flex;
				flex-direction: column;
				gap: 0.75em;
			}
			.card-body h2 {
				margin: 0;
				font-size: 1.2rem;
			}
			.card-body p {
				margin: 0;
				color: rgb(var(--gray-dark));
				font-size: 0.95rem;
				line-height: 1.6;
				flex: 1;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4em;
			}
			.tag {
				font-size: 0.75rem;
				padding: 0.2em 0.6em;
				border-radius: 4px;
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
			}
			.links {
				display: flex;
				gap: 0.75em;
			}
			.links a {
				font-size: 0.9rem;
				text-decoration: none;
				color: var(--accent);
			}
			.links a:hover {
				text-decoration: underline;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Projects</h1>
			<hr />
			<div class="grid">
				{projects.map((project) => (
					<div class="card">
						{project.image
						? <img src={`${base}${project.image}`} alt={project.title + ' screenshot'} style="width:100%;height:180px;object-fit:cover;display:block;" />
						: <div class="card-placeholder">screenshot coming soon</div>
					}
						<div class="card-body">
							<h2>{project.title}</h2>
							<p>{project.description}</p>
							<div class="tags">
								{project.tags.map((tag) => (
									<span class="tag">{tag}</span>
								))}
							</div>
							<div class="links">
								{project.live && <a href={project.live} target="_blank">Live →</a>}
								{project.github && <a href={project.github} target="_blank">GitHub →</a>}
								{project.githubLinks && project.githubLinks.map((link) => (
									<a href={link.url} target="_blank">GitHub ({link.label}) →</a>
								))}
							</div>
						</div>
					</div>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>
